# =========================
# Supabase Edge Functions NPM CONFIG
# =========================

# Required for private package registries (Supabase Edge Functions support)
# Docs: https://supabase.com/docs/guides/functions/import-maps#importing-from-private-registries

registry=https://registry.npmjs.org/

# If you ever use private packages (GitHub, npm private, etc.)
# you can uncomment and configure below:

# @your-scope:registry=https://registry.npmjs.org/
# //registry.npmjs.org/:_authToken=YOUR_NPM_TOKEN

# Improve install consistency (recommended for production builds)
save-exact=true

# Prevent optional dependency issues in edge runtime
optional=false

# Faster installs in CI/CD (Vercel/Supabase deploys)
fund=false
audit=false